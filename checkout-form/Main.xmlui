<Theme tone="dark" fontFamily="Comic Sans MS">
  <Card height="100%" title="hey, XMLUI card here on my island">
    <Form>
      <FormItem bindTo="name" placeholder="Your name"/>
      <FormItem bindTo="email" placeholder="example@something.com"/>
    </Form>
    <Button onClick="modal.open()">Open modal</Button>
    <MyComp/>
  </Card>
  <ModalDialog id="modal" title="myModal"/>
</Theme>
